# Database
DATABASE_URL="postgresql://yoga:yoga_dev_password@localhost:5432/ethical_yoga"

# Auth
PASSKEY_RP_ID="localhost"
PASSKEY_RP_NAME="fair.yoga"

# Cron — shared secret the scheduler sends as `Authorization: Bearer <secret>`
# to /api/cron/*. REQUIRED in production: without it the cron endpoints fail
# closed and no lifecycle automation runs.
CRON_SECRET=""

# In-process job scheduler (class lifecycle, generation, email fallback,
# payment reminders) starts with the server. Set to "off" to disable
# (e.g. when an external scheduler drives /api/cron/* instead).
# CRON_SCHEDULER="off"

# Email
RESEND_API_KEY=""
EMAIL_FROM=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
